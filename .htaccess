# Bizdavar Group — Apache / cPanel
# https://bizdavar.com

# ── General ────────────────────────────────────────────────────────────────
Options -Indexes
DirectoryIndex index.html

# Fix Persian/UTF-8 display (e.g. brand pages served as ????)
AddDefaultCharset UTF-8
AddType 'text/html; charset=UTF-8' .html

# Block dotfiles (.git, .env, etc.)
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# ── LiteSpeed — never cache HTML (stale page cache blocked GTM/deploy updates)
<IfModule LiteSpeed>
  CacheDisable public /
</IfModule>
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# ── Security headers (mod_headers) ───────────────────────────────────────
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

  # CSP — self-hosted fonts; inline scripts for static page boot
  Header set Content-Security-Policy "\
    default-src 'self'; \
    script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; \
    style-src 'self' 'unsafe-inline'; \
    font-src 'self' data:; \
    img-src 'self' data: https:; \
    frame-src 'self' https://www.googletagmanager.com; \
    connect-src 'self' https://ipapi.co https://ipwho.is https://formspree.io https://*.formspree.io https://www.google-analytics.com https://*.google-analytics.com https://www.googletagmanager.com https://analytics.google.com; \
    frame-ancestors 'self'; \
    base-uri 'self'; \
    form-action 'self' mailto: https://formspree.io https://*.formspree.io; \
    upgrade-insecure-requests"

  # Cache static assets in browser (no CSP on images/fonts — breaks SVG <text> in <img>)
  <FilesMatch "\.(css|js|png|jpe?g|webp|svg|gif|ico|woff2?)$">
    Header unset Content-Security-Policy
    Header set Cache-Control "public, max-age=604800, immutable"
  </FilesMatch>
</IfModule>

# ── Compression (mod_deflate) ──────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

# ── Clean URLs + HTTPS (mod_rewrite) ───────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # PHP API & admin — do not rewrite to .html
  RewriteRule ^api/ - [L]
  RewriteRule ^admin/ - [L]

  # www → apex
  RewriteCond %{HTTP_HOST} ^www\.bizdavar\.com [NC]
  RewriteRule ^ https://bizdavar.com%{REQUEST_URI} [R=301,L]

  # HTTP → HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # /index.html → /
  RewriteRule ^index\.html$ / [R=301,L,NC]

  # /fa/ prefix → root (Persian is default, no /fa/ in URLs)
  RewriteRule ^fa/?(.*)$ /$1 [R=301,L]

  # Locale-prefixed URLs — BEFORE trailing-slash strip and generic .html rewrite
  RewriteRule ^(tr|en)/?$ index.html [L]
  RewriteRule ^(tr|en)/blog/?$ pages/blog.html [L]
  RewriteRule ^(tr|en)/pages/(.+?)/?$ pages/$2.html [L]

  # /pages/foo/ → /pages/foo (skip /tr/ and /en/ locale homes)
  RewriteCond %{REQUEST_URI} !^/(tr|en)/?$
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} ^(.+)/$
  RewriteRule ^ %1 [R=301,L]

  # /blog → /pages/blog (legacy URL — external canonical redirect)
  RewriteCond %{THE_REQUEST} \s/blog[\s?] [NC]
  RewriteRule ^blog/?$ /pages/blog [R=301,L]

  # Legacy typo: fguard → fxguard (old HTML referenced fguard/*.webp)
  RewriteRule ^pages/fguard/?$ /pages/fxguard [R=301,L]
  RewriteRule ^assets/images/products/fguard/fguard-hero\.webp$ /assets/images/products/fxguard/fxguard-hero.svg [R=301,L]
  RewriteRule ^assets/images/products/fguard/(.*)$ /assets/images/products/fxguard/$1 [R=301,L]

  # Internal serve /blog and /pages/blog without .html
  RewriteRule ^blog/?$ pages/blog.html [L]
  RewriteRule ^pages/blog/?$ pages/blog.html [L]

  # External redirect: *.html → extensionless (preserve query string)
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L,NE]

  # Internal rewrite: /pages/foo → /pages/foo.html (skip locale home paths)
  RewriteCond %{REQUEST_URI} !^/(tr|en)/?$
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# ── Expires (mod_expires) ──────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType font/woff2 "access plus 30 days"
</IfModule>
