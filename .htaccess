# Bizdavar Group — Apache / cPanel
# https://bizdavar.com

# ── General ────────────────────────────────────────────────────────────────
Options -Indexes
DirectoryIndex index.html

# Fix Persian/UTF-8 display (e.g. brand pages served as ????)
AddDefaultCharset UTF-8
AddType 'text/html; charset=UTF-8' .html

# Block dotfiles (.git, .env, etc.)
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# ── Security headers (mod_headers) ───────────────────────────────────────
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

  # CSP — self-hosted fonts; inline scripts for static page boot
  Header set Content-Security-Policy "\
    default-src 'self'; \
    script-src 'self' 'unsafe-inline'; \
    style-src 'self' 'unsafe-inline'; \
    font-src 'self' data:; \
    img-src 'self' data: https:; \
    connect-src 'self' https://ipapi.co https://ipwho.is https://formspree.io https://*.formspree.io; \
    frame-ancestors 'self'; \
    base-uri 'self'; \
    form-action 'self' mailto: https://formspree.io https://*.formspree.io; \
    upgrade-insecure-requests"

  # Cache static assets in browser
  <FilesMatch "\.(css|js|png|jpe?g|webp|svg|gif|ico|woff2?)$">
    Header set Cache-Control "public, max-age=604800, immutable"
  </FilesMatch>
</IfModule>

# ── Compression (mod_deflate) ──────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

# ── Clean URLs + HTTPS (mod_rewrite) ───────────────────────────────────────
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # www → apex
  RewriteCond %{HTTP_HOST} ^www\.bizdavar\.com [NC]
  RewriteRule ^ https://bizdavar.com%{REQUEST_URI} [R=301,L]

  # HTTP → HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # /index.html → /
  RewriteRule ^index\.html$ / [R=301,L,NC]

  # External redirect: *.html → extensionless (preserve query string)
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L,NE]

  # Internal rewrite: /pages/foo → /pages/foo.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# ── Expires (mod_expires) ──────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType font/woff2 "access plus 30 days"
</IfModule>
